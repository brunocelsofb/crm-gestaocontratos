# Variáveis de ambiente — copie este arquivo para .env.local
# e preencha com os valores do seu projeto Supabase
# (Project Settings > API no painel do Supabase).
#
# NÃO tenho certeza se os nomes exatos dessas variáveis mudaram
# nas versões mais recentes do SDK do Supabase — confirme contra
# a documentação oficial (supabase.com/docs) ou o template gerado
# automaticamente quando você criar o projeto.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave de serviço — uso restrito a server-side (nunca expor no client)
SUPABASE_SERVICE_ROLE_KEY=
